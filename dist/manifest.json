{
  "manifest_version": 3,
  "name": "KidShield",
  "version": "1.0",
  "description": "Dynamically filters and replaces explicit content on web pages with child-friendly text using AI.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KidShield Control"
  }
}
